# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/china_smm_os
# Connection pool (optional — defaults shown)
# DB_POOL_SIZE=15
# DB_MAX_OVERFLOW=15
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800
# DB_PROBE_CONCURRENCY=4
# HEALTH_SNAPSHOT_ENABLED=false
# ROUTE_PROBING_ENABLED=false

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# ── File Storage ──────────────────────────────────────────────────────────────
# Development: leave USE_S3=false, files go to ./media_storage
# Production:  set USE_S3=true and fill in S3 credentials
USE_S3=false
MEDIA_LOCAL_PATH=./media_storage
# Base URL for serving media files to the frontend. Must be reachable from the browser.
# In Docker: http://localhost:8000  |  In production: https://yourdomain.com
MEDIA_BASE_URL=http://localhost:8000

# S3-compatible storage (MinIO, Cloudflare R2, AWS S3, etc.)
S3_BUCKET=china-smm-os
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
# Generate secrets: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string
# Production — use distinct values (required for Admin Security Hardening v1):
# APP_ENV=production
# ADMIN_SECRET_KEY=<long-random-secret>
# TENANT_SECRET_KEY=<different-long-random-secret>
ADMIN_SECRET_KEY=
TENANT_SECRET_KEY=
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Set to true to test AI generation without OpenAI key (placeholder captions)
DEMO_MODE=false

# Telegram Bot (optional — enables content inbox from Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
TELEGRAM_WEBHOOK_SECRET=

# WhatsApp Business API (Meta Cloud API) — optional; demo mode works without credentials
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Platform admin bootstrap (development only — no default credentials)
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
